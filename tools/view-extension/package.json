{
  "name": "genexus-view-tools",
  "displayName": "GeneXus .view Tools",
  "description": "Syntax highlighting, linting (GXV001–GXV010), and autocomplete for GeneXus 18 .view files (User Controls, WBC, WBP).",
  "publisher": "genexus-ai-toolkit",
  "version": "0.1.0",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucaskarsten/genexus-ai-toolkit",
    "directory": "tools/view-extension"
  },
  "homepage": "https://github.com/lucaskarsten/genexus-ai-toolkit/tree/master/tools/view-extension",
  "bugs": { "url": "https://github.com/lucaskarsten/genexus-ai-toolkit/issues" },
  "keywords": ["genexus", "gx18", "user-control", "view", "uc", "wbc", "wbp"],
  "categories": ["Programming Languages", "Linters", "Snippets"],
  "galleryBanner": { "color": "#1e1e2e", "theme": "dark" },
  "engines": { "vscode": "^1.85.0" },
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "activationEvents": ["onLanguage:genexus-view"],
  "contributes": {
    "languages": [
      {
        "id": "genexus-view",
        "aliases": ["GeneXus View", "genexus-view"],
        "extensions": [".view"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "genexus-view",
        "scopeName": "source.genexus-view",
        "path": "./syntaxes/genexus-view.tmLanguage.json",
        "embeddedLanguages": {
          "source.js": "javascript",
          "source.css": "css",
          "text.html.basic": "html"
        }
      }
    ]
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0"
  }
}
