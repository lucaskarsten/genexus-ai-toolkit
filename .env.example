# ── GeneXus Compiler Output ──────────────────────────────────────────────
# Where GeneXus deploys compiled/static files (varies by compiler/platform)
# Tomcat example:  C:\tomcat\webapps\YourApp\static
# .NET example:    C:\inetpub\wwwroot\YourApp\static
# Other:           set your custom path below
GX_COMPILER_OUTPUT=
# Tomcat example:    C:\KBs\YourApp\javaoracle\Web
# .NET example:      C:\KBs\YourApp\netcore\Web

# ── Output Staging Area ──────────────────────────────────────────────────
# Where this toolkit drops AI-generated code (dev copies from here to IDE)
GX_OUTPUT_PATH=.\output

# ── Knowledge Base (SQL features) ────────────────────────────────────────
# Root folder of the GeneXus KB (contains the .gxw file)
GX_KB_PATH=
GX_KB_SERVER=localdb\MSSQLLocalDB
GX_KB_DATABASE=GX_KB_YourKnowledgeBase

# ── Project Settings ─────────────────────────────────────────────────────
# Prefix used in generated object names (e.g. "Acme" → UcAcmeButton)
GX_PROJECT_PREFIX=YourApp
