  "response": "<style>\n  .iai-wrapper      { font-family:OpenSans-Regular; padding:8px 0; box-sizing:border-box; }\n  .iai-btn          { display:inline-flex; align-items:center; gap:6px;\n                      padding:6px 14px; border:1px solid #d0d0d0; background:#f8f9fa;\n                      border-radius:4px; cursor:pointer; font-size:13px; color:#333;\n                      font-family:inherit; }\n  .iai-btn:hover    { background:#e9ecef; }\n  .iai-btn:disabled { opacity:.6; cursor:wait; }\n  .iai-icon         { font-size:14px; }\n  .iai-loading      { padding:8px 0; color:#666; font-size:13px; font-style:italic;\n                      display:none; }\n  .iai-loading.on   { display:block; }\n  .iai-resultado    { display:none; margin-top:8px; padding:12px;\n                      background:#f0f7ff; border-left:3px solid #2c7be5;\n                      border-radius:4px; }\n  .iai-resultado.on { display:block; }\n  .iai-header       { display:flex; align-items:center; gap:6px;\n                      margin-bottom:6px; font-size:13px; color:#2c7be5; }\n  .iai-titulo       { flex:1; font-weight:600; }\n  .iai-fechar       { background:none; border:none; font-size:18px;\n                      cursor:pointer; color:#666; line-height:1; padding:0 4px; }\n  .iai-fechar:hover { color:#000; }\n  .iai-texto        { font-size:13px; line-height:1.5; color:#333; }\n  .iai-texto p      { margin:0 0 8px 0; }\n  .iai-texto p:last-child { margin-bottom:0; }\n  .iai-erro         { display:none; margin-top:8px; padding:8px 12px;\n                      background:#fff3f3; border-left:3px solid #d9534f;\n                      color:#842029; font-size:13px; border-radius:4px; }\n  .iai-erro.on      { display:block; }\n</style>\n\n<div id=\"iai-data-{{ucid}}\"\n     data-tipo=\"{{TipoConteudo}}\"\n     data-nome=\"{{NomeConteudo}}\"\n     data-ucid-alvo=\"{{UcidAlvo}}\"\n     data-contexto=\"{{Contexto}}\"\n     data-und-id=\"{{UndId}}\"\n     data-url=\"{{UrlGerarInsight}}\"\n     data-language=\"{{Language}}\"\n     style=\"display:none\">{{DadosJsonManual}}</div>\n\n<div id=\"iai-{{ucid}}\" class=\"iai-wrapper\">\n  <button type=\"button\" class=\"iai-btn\" id=\"iai-btn-{{ucid}}\">\n    <span class=\"iai-icon\">✨</span>\n    <span>{{TextoBotao}}</span>\n  </button>\n\n  <div class=\"iai-loading\" id=\"iai-loading-{{ucid}}\">\n    Analisando dados...\n  </div>\n\n  <div class=\"iai-resultado\" id=\"iai-resultado-{{ucid}}\">\n    <div class=\"iai-header\">\n      <span class=\"iai-icon\">✨</span>\n      <span class=\"iai-titulo\">Insight</span>\n      <button type=\"button\" class=\"iai-fechar\" id=\"iai-fechar-{{ucid}}\">×</button>\n    </div>\n    <div class=\"iai-texto\" id=\"iai-texto-{{ucid}}\"></div>\n  </div>\n\n  <div class=\"iai-erro\" id=\"iai-erro-{{ucid}}\"></div>\n</div>\n\n<script>\n  (function() {\n    var ucid = \"{{ucid}}\";\n\n    var dataEl       = document.getElementById(\"iai-data-\" + ucid);\n    var btn          = document.getElementById(\"iai-btn-\" + ucid);\n    var btnFechar    = document.getElementById(\"iai-fechar-\" + ucid);\n    var loadingEl    = document.getElementById(\"iai-loading-\" + ucid);\n    var resultadoEl  = document.getElementById(\"iai-resultado-\" + ucid);\n    var textoEl      = document.getElementById(\"iai-texto-\" + ucid);\n    var erroEl       = document.getElementById(\"iai-erro-\" + ucid);\n\n    if (!dataEl || !btn) return;\n\n    function obterDados() {\n      // Modo manual: prioriza JSON passado por parâmetro\n      var dadosManual = dataEl.textContent.trim();\n      if (dadosManual && dadosManual !== \"\" && dadosManual !== \"[]\") {\n        return dadosManual;\n      }\n\n      // Modo auto: tenta ler div hidden do UC alvo (padrão FoccoLojas)\n      var ucidAlvo = dataEl.getAttribute(\"data-ucid-alvo\");\n      if (!ucidAlvo) return null;\n\n      var prefixos = [\"bca-data-\", \"dnt-data-\", \"lnc-data-\", \"pzz-data-\",\n                      \"brc-data-\", \"data-\"];\n\n      for (var i = 0; i < prefixos.length; i++) {\n        var div = document.getElementById(prefixos[i] + ucidAlvo);\n        if (div && div.textContent.trim() !== \"\") {\n          return div.textContent.trim();\n        }\n      }\n\n      return null;\n    }\n\n    function mostrarErro(msg) {\n      loadingEl.classList.remove(\"on\");\n      btn.disabled = false;\n      erroEl.textContent = msg || \"Erro ao gerar insight.\";\n      erroEl.classList.add(\"on\");\n    }\n\n    function mostrarResultado(texto) {\n      loadingEl.classList.remove(\"on\");\n      btn.disabled = false;\n      var html = texto.replace(/&/g, '&amp;')\n                      .replace(/</g, '&lt;')\n                      .replace(/>/g, '&gt;');\n      html = \"<p>\" + html.replace(/\\n\\n+/g, \"</p><p>\").replace(/\\n/g, \"<br>\") + \"</p>\";\n      textoEl.innerHTML = html;\n      resultadoEl.classList.add(\"on\");\n    }\n\n    function esconderTudo() {\n      resultadoEl.classList.remove(\"on\");\n      erroEl.classList.remove(\"on\");\n    }\n\n    function gerar() {\n      var dadosJson = obterDados();\n\n      if (!dadosJson) {\n        mostrarErro(\"Não foi possível localizar os dados.\");\n        return;\n      }\n\n      esconderTudo();\n      btn.disabled = true;\n      loadingEl.classList.add(\"on\");\n\n      var url = dataEl.getAttribute(\"data-url\");\n\n      var payload = {\n        TipoConteudo: dataEl.getAttribute(\"data-tipo\"),\n        NomeConteudo: dataEl.getAttribute(\"data-nome\"),\n        DadosJson:    dadosJson,\n        Contexto:     dataEl.getAttribute(\"data-contexto\"),\n        UndId:        parseInt(dataEl.getAttribute(\"data-und-id\") || \"0\", 10)\n      };\n\n      fetch(url, {\n        method:  \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body:    JSON.stringify(payload),\n        credentials: \"include\"\n      })\n      .then(function(r) {\n        if (!r.ok) throw new Error(\"HTTP \" + r.status);\n        return r.json();\n      })\n      .then(function(resp) {\n        if (resp.ErroCodigo && resp.ErroCodigo !== 0) {\n          mostrarErro(resp.ErroDescricao);\n        } else {\n          mostrarResultado(resp.InsightTexto);\n        }\n      })\n      .catch(function(err) {\n        mostrarErro(\"Falha na comunicação. Tente novamente.\");\n      });\n    }\n\n    btn.addEventListener(\"click\", gerar);\n    btnFechar.addEventListener(\"click\", esconderTudo);\n  })();\n</script>\n",
