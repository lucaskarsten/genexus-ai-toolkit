{
  "name": "gx18-mcp",
  "version": "1.9.2",
  "description": "MCP server for GeneXus 18 â€” native SDK access without UserId corruption",
  "keywords": [
    "genexus",
    "mcp",
    "gx18",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucaskarsten/genexus-ai-toolkit.git",
    "directory": "packages/gx18-mcp"
  },
  "homepage": "https://github.com/lucaskarsten/genexus-ai-toolkit/tree/master/packages/gx18-mcp",
  "bin": {
    "gx18-mcp": "dist/bin/gx18-mcp.js"
  },
  "main": "dist/src/server.js",
  "files": [
    "dist/bin",
    "dist/src",
    "dist/worker",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "build:worker": "powershell -File scripts/build-worker.ps1",
    "build:exe": "node scripts/gen-icon.js && pkg dist/bin/launcher.js --target node18-win-x64 --output release/GeneXusAIToolkit.exe --icon assets/icon.ico",
    "build:release": "npm run build && npm run build:exe && node scripts/build-release.js",
    "watch": "node esbuild.config.js --watch",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "test:worker": "powershell -File scripts/test-worker.ps1",
    "prepublishOnly": "npm run build"
  },
  "pkg": {
    "scripts": [
      "dist/src/**/*.js"
    ],
    "assets": [
      "dist/worker/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "release"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "dotenv": "^16.0.0",
    "inquirer": "^9.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.0.0",
    "@yao-pkg/pkg": "^5.12.1",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.20.2": true,
    "oracledb@6.10.0": true
  }
}
